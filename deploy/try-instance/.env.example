# .env.example — copy to .env on the VPS before `docker compose up -d`.
#
# Traefik / Let's Encrypt:
LETSENCRYPT_EMAIL=

# Webhook (Slack/Discord/email gateway) hit by reset.sh after each
# daily wipe. Optional — leave empty to skip the ping.
RESET_WEBHOOK_URL=

# Webhook hit by monitor.sh when /health stops responding. Strongly
# recommended in production — this is the only outbound alert path.
MONITOR_WEBHOOK_URL=

# Per-IP rate limit applied by Traefik. 120 requests / minute is
# generous for a manual demo session and tight enough to absorb a
# casual abuse spike before Cloudflare's WAF kicks in.
SYNTRA_RATE_LIMIT_RPM=120
SYNTRA_RATE_LIMIT_BURST=30

# Which capsule the in-image traffic generator drives. The other
# three are still installed and visible in the dashboard's switcher.
# One of:
#   predictive-autoscaling   (default)
#   anomaly-routing
#   seasonal-fraud-threshold
#   hierarchical-region-routing
SYNTRA_DEMO_CAPSULE=predictive-autoscaling
